{
  "name": "my-astro-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:all": "pnpm type-check && pnpm lint && pnpm format:check",
    "check:ci": "pnpm type-check && pnpm lint && pnpm format:check && pnpm test"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^24.0.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^0.34.0",
    "eslint-plugin-boundaries": "^5.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jiti": "^2.4.2",
    "@astrojs/check": "^0.9.4"
  }
}
