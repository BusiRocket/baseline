{
  "name": "my-astro-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "fix": "pnpm lint:fix && pnpm format",
    "format": "prettier --write . --list-different",
    "format:check": "prettier --check .",
    "type-check": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:all": "pnpm type-check && pnpm lint && pnpm format:check",
    "check:ci": "pnpm type-check && pnpm lint && pnpm format:check && pnpm test",
    "test:a11y": "vitest run",
    "perf:check": "pnpm build && lhci autorun --config=.lighthouserc.json"
  },
  "dependencies": {
    "astro": "^6.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@busirocket/eslint-config": "^0.1.0",
    "@busirocket/prettier-config": "^0.1.0",
    "@busirocket/tsconfig": "^0.1.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-code-policy": "^0.2.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4",
    "@lhci/cli": "^0.15.1"
  }
}
