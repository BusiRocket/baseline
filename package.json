{
  "name": "engineering-baseline",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "lint": "pnpm --filter @repo/eslint-config lint && pnpm --filter './templates/*' lint",
    "lint:fix": "pnpm --filter @repo/eslint-config lint:fix && pnpm --filter './templates/*' lint:fix",
    "type-check": "pnpm --filter @repo/eslint-config type-check && pnpm --filter './templates/*' type-check",
    "format": "prettier --write . --list-different",
    "format:check": "prettier --check .",
    "check:all": "pnpm type-check && pnpm lint && pnpm format:check",
    "check:ci": "pnpm type-check && pnpm lint && pnpm format:check && pnpm --filter './templates/*' test"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2",
    "jiti": "^2.6.1"
  }
}
