{
  "name": "engineering-baseline",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write . --list-different",
    "format:check": "prettier --check .",
    "check:all": "turbo run type-check lint:fix && pnpm format",
    "fix:all": "turbo run fix && pnpm format",
    "check:ci": "turbo run type-check lint test build && pnpm format:check",
    "perf:check": "turbo run perf:check"
  },
  "devDependencies": {
    "@busirocket/prettier-config": "workspace:*",
    "@types/node": "^20.19.39",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  }
}
