{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "Next.js app — extends app, adds Next plugin, JSX runtime, and Next includes.",
  "extends": "./app.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build", ".next"]
}
