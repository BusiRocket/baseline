{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "Node.js / tooling-only package — no DOM, no JSX, types=node.",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2024"],
    "types": ["node"],
