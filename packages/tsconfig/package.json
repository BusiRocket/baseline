{
  "name": "@vibracomet/tsconfig",
  "version": "0.1.0",
  "private": false,
  "description": "Shared TypeScript configuration baseline",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "*.json"
  ],
  "exports": {
    "./base.json": "./base.json",
    "./app.json": "./app.json",
    "./nextjs.json": "./nextjs.json",
    "./astro.json": "./astro.json",
    "./vite-react.json": "./vite-react.json",
    "./node.json": "./node.json"
  },
  "scripts": {
    "fix": "prettier --write \"*.json\" --list-different"
  }
}
