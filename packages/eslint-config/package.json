{
  "name": "@repo/eslint-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ESLint configuration baseline",
  "type": "module",
  "files": [
    "src",
    "eslint.config.ts",
    "tsconfig.json"
  ],
  "exports": {
    "./base": "./src/base.ts",
    "./nextjs": "./src/nextjs.ts",
    "./astro": "./src/astro.ts",
    "./vite-react": "./src/vite-react.ts",
    "./node": "./src/node.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@eslint/js": ">=9.0.0",
    "eslint": ">=9.0.0",
    "eslint-config-next": ">=15.0.0",
